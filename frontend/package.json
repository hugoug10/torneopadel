{
  "name": "torneo-padel-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npm run build && wrangler pages dev ./dist",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "deploy": "npm run build && wrangler pages deploy ./dist --project-name=torneo-padel",
    "db:migrate:local": "wrangler d1 execute torneo-padel-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute torneo-padel-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "vite": "^5.4.6",
    "wrangler": "^4.101.0"
  }
}
